# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://mooos:mooos@localhost:5432/mooos

# ── Auth / JWT ────────────────────────────────────────────
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=MooOSBot
TELEGRAM_GROUP_PAKAN=-1001234567890
TELEGRAM_GROUP_SUSU=-1009876543210
TELEGRAM_GROUP_PUPUK=-1005555555555

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Business defaults ────────────────────────────────────
DEFAULT_FEED_KG_PER_COW_PER_DAY=10.0
DEFAULT_WASTE_KG_PER_COW_PER_DAY=10.0
DEFAULT_FERMENTATION_DAYS=14
FEED_CRITICAL_DAYS_THRESHOLD=7
FERTILIZER_READY_MIN_KG=500.0
PROFIT_SHARE_KOPERASI=0.6
PROFIT_SHARE_MEMBER=0.4
